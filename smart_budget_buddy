expenses = []
budget_limit = 0
filename = "expenses.txt"


def set_budget():
    global budget_limit
    budget_limit = float(input("Enter your budget limit: $"))
    print(f"Budget set to ${budget_limit:.2f}\n")


def add_expense():
    category = input("Enter category: ")
    amount = float(input("Enter amount: "))
    expense = {"category": category, "amount": amount}
    expenses.append(expense)
    print("Expense added successfully.")

    check_budget()
    print()


def show_expenses():
    if not expenses:
        print("No expenses recorded.\n")
        return

    print("\nExpenses:")
    for expense in expenses:
        print(f"{expense['category']}: ${expense['amount']:.2f}")
    print()


def calculate_total():
    total = 0
    for expense in expenses:
        total += expense["amount"]
    print(f"Total spent: ${total:.2f}\n")
    return total


def category_summary():
    if not expenses:
        print("No expenses recorded.\n")
        return

    summary = {}
    for expense in expenses:
        category = expense["category"]
        amount = expense["amount"]

        if category in summary:
            summary[category] += amount
        else:
            summary[category] = amount

    print("\nSpending by Category:")
    for category, amount in summary.items():
        print(f"{category}: ${amount:.2f}")
    print()


def check_budget():
    if budget_limit == 0:
        return

    total = 0
    for expense in expenses:
        total += expense["amount"]

    if total > budget_limit:
        print("Warning: You have exceeded your budget!")
    elif total >= budget_limit * 0.9:
        print("Alert: You are close to reaching your budget.")


def save_expenses():
    with open(filename, "w") as file:
        for expense in expenses:
            line = f"{expense['category']},{expense['amount']}\n"
            file.write(line)

    print("Expenses saved to file.\n")


def main():
    while True:
        print("Smart Budget Buddy")
        print("1. Set Budget")
        print("2. Add Expense")
        print("3. Show Expenses")
        print("4. Show Total Spending")
        print("5. Show Category Summary")
        print("6. Save Expenses")
        print("7. Exit")

        choice = input("Choose an option: ")

        if choice == "1":
            set_budget()
        elif choice == "2":
            add_expense()
        elif choice == "3":
            show_expenses()
        elif choice == "4":
            calculate_total()
        elif choice == "5":
            category_summary()
        elif choice == "6":
            save_expenses()
        elif choice == "7":
            print("Goodbye!")
            break
        else:
            print("Invalid choice. Try again.\n")


main()
